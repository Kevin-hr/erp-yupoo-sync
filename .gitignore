# ============================================
# Claude Code ERP Sync Project - .gitignore
# 标准文件管理规范
# ============================================

# ============================================
# 1. Claude Code 工作目录（禁止跟踪）
# ============================================
.claude/
.claude/**/
.cursors/
.cursors/**/

# ============================================
# 2. 临时草稿与中转站（禁止跟踪）
# ============================================
.dumate/
.dumate/**/
.dumate/inbox/

# ============================================
# 3. 规划与草稿目录（禁止跟踪）
# ============================================
.planning/drafts/
.planning/phases/*/phase.md
.sisyphus/
.sisyphus/**/

# ============================================
# 4. Python
# ============================================
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
*.pyc
*.pyo
.venv/
venv/

# ============================================
# 5. 日志与状态文件
# ============================================
logs/
*.log
logs/*.json
logs/*.xlsx
*.state.json
pipeline_state.json

# ============================================
# 6. Screenshots（禁止跟踪）
# ============================================
screenshots/
screenshots/**/

# ============================================
# 7. Cookies（禁止跟踪）
# ============================================
cookies.json
logs/cookies.json
logs/yupoo_cookies.json

# ============================================
# 8. OS 临时文件
# ============================================
.DS_Store
Thumbs.db
Desktop.ini
~$*.xlsx
~$*.doc*

# ============================================
# 9. 图片（禁止跟踪）
# ============================================
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.svg
!docs/*.svg

# ============================================
# 10. Editor 配置
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~

# ============================================
# 11. Playwright CLI（禁止跟踪）
# ============================================
.playwright-cli/
.playwright-cli/**/

# ============================================
# 12. 临时输出目录（禁止跟踪）
# ============================================
output/
temp/
tmp/
*.tmp

# ============================================
# 13. Windows 保留设备名
# ============================================
nul
con
prn
aux

# ============================================
# 14. 测试数据与调试文件
# ============================================
test_*.json
test_*.csv
debug_*.html
smoke_test.json
batch_example.json

# ============================================
# 15. 代码审查产出物（禁止跟踪）
# ============================================
REVIEW.md
REVIEW-*.md
AUDIT*.md
debug_page.html

# ============================================
# 16. Excel 临时文件（禁止跟踪）
# ============================================
*.xlsx
!docs/**/*.xlsx
!inputs/**/*.xlsx
!templates/**/*.xlsx

# ============================================
# 17. Windows 保留设备名
# ============================================
nul
